{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./build",

		"strict": true,

		"target": "es2022",
		"lib": ["esnext", "DOM", "DOM.Iterable", "DOM.AsyncIterable"],

		"module": "esnext",
		"moduleResolution": "bundler",

		"noUnusedLocals": true,
		"noUnusedParameters": true,

		"incremental": true,
		"tsBuildInfoFile": "./build/.tsbuildinfo"
	},
	"include": ["./src", "./src/global.d.ts"]
}
